# router-1 dynamic multicast method

# assign eth0 ip address
ip addr add 10.0.0.1/30 dev eth0
ip link set eth0 up

# set eth1 up
ip link set eth1 up

# test reachability of router-2
ping 10.0.0.2

# create a VXLAN interface
ip link add vxlan10 type vxlan id 10 dev eth0 local 10.0.0.1 group 239.1.1.1 dstport 4789
ip link set vxlan10 up

# create the bridge:

ip link add name br0 type bridge
ip link set br0 up

# enslave both eth1 and vxlan10 to br0
ip link set eth1 master br0
ip link set vxlan10 master br0

# check bridge
bridge link
bridge fdb show

# check group in vxlan10
ip -d link show vxlan10

# see encapsulated packets when pinging
tcpdump -i eth0 udp port 4789
